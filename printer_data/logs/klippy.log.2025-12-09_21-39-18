	G1 X{center_x} Y{center_y + radius_y} F{vars.wipe_spd_xy / 2}
	G1 X{center_x - radius_x} Y{center_y} F{vars.wipe_spd_xy / 2}
	G1 X{center_x} Y{center_y - radius_y} F{vars.wipe_spd_xy / 2}
	G1 X{center_x + radius_x} Y{center_y} F{vars.wipe_spd_xy / 2}
	{% endfor %}
	SET_FAN_SPEED FAN=cooling_fan SPEED={backup_fan_speed}
	RESTORE_GCODE_STATE NAME=PURGE_WIPE_state

