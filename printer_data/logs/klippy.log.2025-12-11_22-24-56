	MMU_LOG MSG="Unloading filament on print end"
	MMU_UNLOAD RESTORE=0
	{% endif %}
	
	{% if reset_ttg %}
	MMU_TTG_MAP RESET=1 QUIET=1
	{% endif %}
	
