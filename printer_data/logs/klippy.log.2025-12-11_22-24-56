	_MMU_EVENT EVENT="filament_cut"
	
	
	{% set effective_pushback_length = [pushback_length, retract_length - printer.mmu.extruder_filament_remaining - park_vars.retracted_length]|min %}
	{% if effective_pushback_length > 0 %}
