	{% endif %}
	SET_GCODE_VARIABLE MACRO=_MMU_PARK VARIABLE=retracted_length VALUE=0
	{% else %}
	MMU_LOG MSG="Extruder is not hot enough to un-retract" DEBUG=1
	{% endif %}

[gcode_macro _MMU_CLEAR_POSITION]
