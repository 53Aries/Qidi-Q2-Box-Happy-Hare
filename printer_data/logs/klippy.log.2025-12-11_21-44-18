	{% endif %}
	{% if not (printer.toolhead.position.x == Px and printer.toolhead.position.y == Py) %}
	G1 X{Px} Y{Py} F{Se}
	{% endif %}
	G1 X{Pxe} Y{Pye} F{Se}

