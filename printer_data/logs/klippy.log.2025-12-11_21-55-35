	MMU_STATS COUNTER=mmu_restarts INCR=1
	
	{% set vendor = printer.configfile.config.mmu_machine.mmu_vendor|string|lower %}
	{% set version = printer.configfile.config.mmu_machine.mmu_version|string|lower %}
