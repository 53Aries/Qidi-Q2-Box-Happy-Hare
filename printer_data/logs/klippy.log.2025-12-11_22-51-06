	{% endif%}
	
	
	
	
	
	{% if printer.extruder.temperature < vars.purge_temp_min - 2 %}
	RESPOND MSG="PURGE: Heating Extruder to MIN"
	{% if printer.extruder.target < vars.purge_temp_min %}
