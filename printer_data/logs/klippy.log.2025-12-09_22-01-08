	{% endif %}
	{% endif %}
	
	
	_CUT_TIP_ADJUST_CURRENT
	_CUT_TIP_MOVE_TO_CUTTER_PIN PIN_PARK_X_LOC={pin_park_x_loc} PIN_PARK_Y_LOC={pin_park_y_loc}
	_CUT_TIP_GANTRY_SERVO_DOWN
