[gcode_macro BUCKET_PURGE]
gcode = 
	{% set vars = printer['gcode_macro PURGE_VARIABLES'] %}
	
	
	
	
	
	
	SAVE_GCODE_STATE NAME=BUCKET_PURGE_state
	
	
	
	
	
	
	{% if "xyz" not in printer.toolhead.homed_axes %}
