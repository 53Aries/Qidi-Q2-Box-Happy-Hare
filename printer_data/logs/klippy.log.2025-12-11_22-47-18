	{% set Px = printer["gcode_macro PURGE_VARIABLES"].purge_x|float %}
	{% set Py = printer["gcode_macro PURGE_VARIABLES"].purge_y|float %}
	{% set Pxe = printer["gcode_macro PURGE_VARIABLES"].purge_x_entry|float %}
