[octoprint_compat]

[history]

[file_manager]
enable_object_processing = True

[timelapse]
output_path = ~/printer_data/timelapse/
frame_path = /tmp/timelapse/printer

[update_manager mainsail]
type = web
channel = stable
repo = mainsail-crew/mainsail
path = ~/mainsail

[update_manager happy-hare]
type = git_repo
path = ~/Happy-Hare
origin = https://github.com/moggieuk/Happy-Hare.git
primary_branch = main
managed_services = klipper

[update_manager printer_config]
type = git_repo
path = ~/printer_data/config
origin = https://github.com/53Aries/Qidi-Q2-Box-Happy-Hare.git
primary_branch = main
managed_services = klipper
is_system_service = False

[update_manager qidi_klipper]
type = git_repo
path = ~/klipper
origin = https://github.com/53Aries/Qidi-Q2-Box-Happy-Hare.git
primary_branch = main
managed_services = klipper
env = ~/klippy-env/bin/python
requirements = klipper/scripts/klippy-requirements.txt
install_script = klipper/scripts/install-octopi.sh

[mmu_server]
enable_file_preprocessor = True
enable_toolchange_next_pos = True
update_spoolman_location = True

