[gcode_macro UNLOAD_FILAMENT]
gcode = 
	{% if printer.save_variables.variables.enable_box == 1 %}
	{% set T = params.T|int %}
	CUT_FILAMENT T={T}
	MOVE_TO_TRASH
	UNLOAD_T{T}
	G1 E25 F300
	M104 S0
	CLEAR_OOZE
	CLEAR_FLUSH
	{% endif %}

