	{% set center_x = vars.brush_start + vars.brush_width / 2 %}
	{% set center_y = vars.brush_Y_position + vars.brush_depth / 2 %}
	{% set radius_x = vars.brush_width / 2 %}
	{% set radius_y = vars.brush_depth / 2 %}
