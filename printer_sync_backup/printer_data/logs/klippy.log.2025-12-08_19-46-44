	{% set hotendtemp = params.S|default(250)|int %}
	{% set mode = params.T|default(0)|int %}
	{% if mode == 0 %}
	_CG28
	MOVE_TO_TRASH
	{% endif %}
	
	
	
	
	{% if mode == 0 %}
	M104 S{hotendtemp}
	MOVE_TO_TRASH
	M109 S{hotendtemp}
	M118 Heat up complete
	G92 E0
	G1 E80 F400
	M400
	{% elif mode ==1 %}
	MOVE_TO_TRASH
	M109 S{hotendtemp}
	M118 Heat up complete
	G92 E0
	G1 E80 F400
	M400
	{% endif %}
	M118 Load finish

[gcode_arcs]
resolution = 1.0

[gcode_macro M109]
rename_existing = M99109
gcode = 
	{% set s = params.S|float %}
	
	M104 {% for p in params %}{'%s%s' % (p, params[p])}{% endfor %}
