dout_pin = THR: PB4
voltage = 4.95
delta_v = 0.08
z_offset = -0.07
speed = 5
lift_speed = 5
samples = 2
sample_retract_dist = 3
samples_result = average
samples_tolerance = 0.02
samples_tolerance_retries = 10

[bed_mesh]
