stepper = 

[heater_fan hotend_fan]
pin = THR:PA11
max_power = 1.0
shutdown_speed = 1.0
kick_start_time = 0.5
heater = extruder
heater_temp = 50.0
fan_speed = 1.0
off_below = 0
tachometer_pin = THR:PA12
tachometer_ppr = 2
tachometer_poll_interval = 0.0015

[fan_generic cooling_fan]
