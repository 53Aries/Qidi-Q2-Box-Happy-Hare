[gcode_macro PRINT_START]
gcode = 
	AUTOTUNE_SHAPERS
	DISABLE_ALL_SENSOR
	CLEAR_PAUSE
	
	{% set bedtemp = params.get('BED') | int %}
	{% set hotendtemp = params.get('HOTEND') | int %}
	{% set chambertemp = params.get('CHAMBER', 0) | int %}
